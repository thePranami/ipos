<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity.HomeActivity">

    <LinearLayout
        android:id="@+id/homeAction"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="center_vertical"
        android:background="@color/colorPrimary">
        <ImageView
            android:id="@+id/backFromStore"
            android:layout_width="0dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_back"
            android:layout_gravity="center"
            android:layout_weight="0.1" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Report List"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_gravity="center"
            android:layout_marginLeft="10dp"
            android:layout_weight="0.8" />
        <ImageView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.1"
            android:layout_gravity="center"
            android:src="@drawable/ic_ipos_logout"/>

    </LinearLayout>

    <TextView
        android:id="@+id/txt1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PAHALA BHUBANESWAR IMFL OFF SHOP"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_below="@+id/homeAction"
        android:textColor="@color/black"
        android:gravity="center"/>
    <TextView
        android:id="@+id/txt2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ward no 4 BMC, Khordha,Bhubaneswar, 752055"
        android:textSize="14sp"
        android:layout_below="@+id/txt1"
        android:textColor="@color/blackLight"
        android:gravity="center"/>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorPrimary"
        android:layout_below="@+id/txt2"
        android:layout_marginTop="2dp"/>
    <RelativeLayout
        android:id="@+id/spinRel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txt2"
        android:padding="5dp">
        <Spinner
            android:id="@+id/reportSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/rectangle_shape">
        </Spinner>
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/spinRel"
        android:layout_marginTop="10dp"
        android:padding="10dp">
        <LinearLayout
            android:id="@+id/fromToLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/rl_medium"
                android:textColor="@color/black"
                android:text="From Date:"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/rl_medium"
                android:textColor="@color/black"
                android:text="To Date:"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ftDateLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/fromToLine">
            <TextView
                android:id="@+id/fromDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="07/07/2021"
                android:padding="8dp"
                android:fontFamily="@font/rl_medium"
                android:textSize="16sp"
                android:drawableRight="@drawable/calendar"
                android:background="@drawable/rectangle_shape"/>
            <TextView
                android:id="@+id/toDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="8dp"
                android:layout_marginLeft="1dp"
                android:textSize="16sp"
                android:fontFamily="@font/rl_medium"
                android:drawableRight="@drawable/calendar"
                android:background="@drawable/rectangle_shape"
                android:text="07/07/2021"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/oneDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:layout_below="@+id/ftDateLine">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:fontFamily="@font/rl_medium"
                android:text="Select Date:"/>
            <TextView
                android:id="@+id/date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="07/07/2021"
                android:padding="8dp"
                android:textSize="16sp"
                android:fontFamily="@font/rl_medium"
                android:drawableRight="@drawable/calendar"
                android:background="@drawable/rectangle_shape"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ltcLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_below="@+id/oneDate">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/rl_medium"
                android:textColor="@color/black"
                android:text="Liquor Type:"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/rl_medium"
                android:textColor="@color/black"
                android:text="Liquor Category:"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ltcSubLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/ltcLine">
            <Spinner
                android:id="@+id/typeSpinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/rectangle_shape"/>
            <Spinner
                android:id="@+id/catSpinner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="1dp"
                android:background="@drawable/rectangle_shape" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/onlyType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/ltcSubLine"
            android:layout_marginTop="20dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rl_medium"
                android:textColor="@color/black"
                android:text="Liquor Type:"/>
            <Spinner
                android:id="@+id/onlyTypeSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rectangle_shape"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/onlyCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/onlyType"
            android:layout_marginTop="20dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rl_medium"
                android:textColor="@color/black"
                android:text="Liquor Category:"/>
            <Spinner
                android:id="@+id/onlyCatSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rectangle_shape"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/splrLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/onlyCategory"
            android:layout_marginTop="20dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rl_medium"
                android:textColor="@color/black"
                android:text="Supplier Name:"/>
            <Spinner
                android:id="@+id/splrSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rectangle_shape"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/brandLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/splrLine"
            android:layout_marginTop="20dp"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rl_medium"
                android:textColor="@color/black"
                android:text="Brand Name:"/>
            <Spinner
                android:id="@+id/brandSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rectangle_shape"/>
        </LinearLayout>

    </RelativeLayout>
</RelativeLayout>